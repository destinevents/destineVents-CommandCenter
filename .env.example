# ── Supabase (public — safe to commit) ────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Supabase (server-side only — set in Vercel, NEVER commit) ─────────────────
# Found in: Supabase dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── PayMongo (set in Vercel, NEVER commit) ────────────────────────────────────
# Found in: PayMongo dashboard → Developers → API Keys
# Use sk_test_... for staging, sk_live_... for production
PAYMONGO_SECRET_KEY=sk_test_...

# Found in: PayMongo dashboard → Developers → Webhooks
# Create a webhook pointing to: https://your-domain.vercel.app/api/payments/webhook
# Events to subscribe: checkout_session.payment.paid, link.payment.paid, payment.failed
PAYMONGO_WEBHOOK_SECRET=whsec_...

# ── Anthropic (set in Vercel, NEVER commit) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
