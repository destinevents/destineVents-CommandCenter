{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ai.ts": {
      "memory": 256,
      "maxDuration": 20
    },
    "api/payments/create-checkout.ts": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/payments/create-link.ts": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/payments/webhook.ts": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/login.html",
      "permanent": false
    }
  ]
}
