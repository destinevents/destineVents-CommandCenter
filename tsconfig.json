{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": [
    "js/**/*",
    "services/**/*",
    "utils/**/*",
    "config/**/*",
    "lib/**/*",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
