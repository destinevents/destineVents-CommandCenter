{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@hq/*":     ["apps/hq/*"],
      "@icc/*":    ["apps/icc/*"],
      "@config/*": ["config/*"]
    }
  },
  "include": [
    "apps/**/*",
    "shared/**/*",
    "config/**/*",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
